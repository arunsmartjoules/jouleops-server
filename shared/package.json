{
    "name": "@jouleops/shared",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./lib/*": "./src/lib/*.ts",
        "./utils/*": "./src/utils/*.ts",
        "./middleware/*": "./src/middleware/*.ts",
        "./types/*": "./src/types/*.ts"
    },
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --target bun",
        "test": "if find src \\( -name '*.test.*' -o -name '*.spec.*' \\) -print -quit | grep -q .; then bun test; else echo 'No tests yet — skipping'; fi"
    },
    "dependencies": {
        "firebase-admin": "^13.7.0"
    }
}