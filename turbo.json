{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "persistent": true,
            "cache": false
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**"
            ]
        },
        "start": {
            "dependsOn": [
                "build"
            ]
        },
        "test": {
            "cache": false,
            "env": [
                "DATABASE_URL",
                "SUPABASE_URL",
                "JWT_SECRET"
            ]
        },
        "lint": {
            "cache": true
        }
    }
}