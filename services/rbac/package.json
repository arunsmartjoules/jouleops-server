{
    "name": "@jouleops/rbac",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "src/index.ts",
    "scripts": {
        "dev": "bun --hot src/index.ts",
        "start": "bun src/index.ts",
        "build": "bun build ./src/index.ts --outdir ./dist --target bun",
        "test": "if find src \\( -name '*.test.*' -o -name '*.spec.*' \\) -print -quit | grep -q .; then bun test; else echo 'No tests yet — skipping'; fi"
    },
    "dependencies": {
        "@jouleops/shared": "workspace:*",
        "bcryptjs": "^2.4.3",
        "google-auth-library": "^10.6.1",
        "jsonwebtoken": "^9.0.2",
        "@supabase/supabase-js": "^2.45.4"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.6",
        "@types/supertest": "^6.0.3",
        "supertest": "^7.2.2"
    }
}